PORT=3000
#
# フロント（またはAPI利用元）からアクセスする際の許可オリジン。
# 未指定なら CORS は設定しない（またはデフォルト挙動）として扱う。
#
CORS_ORIGIN=http://localhost:5173

# DB（ルート .env と同値でよい）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=bbs
MYSQL_USER=root
MYSQL_PASSWORD=bbs_dev_root

# 画像
IMAGE_STORAGE_MODE=local
LOCAL_UPLOAD_DIR=uploads
LOCAL_PUBLIC_BASE_URL=http://localhost:3000/uploads

# 本番向け（local 時は未設定可）
AWS_REGION=ap-northeast-1
S3_BUCKET=
CLOUDFRONT_BASE_URL=
