{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node", "jest"],
    "skipLibCheck": true,
    "esModuleInterop": true,

    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,

    "isolatedModules": true

  },
  "include": ["src"]
}

